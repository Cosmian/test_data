{
  "_comment": "Encrypt with RSA-OAEP but a symmetric key must return 422 (key type mismatch)",
  "type": "expect_error",
  "endpoint": "/v1/crypto/encrypt",
  "setup_key": {
    "kty": "oct",
    "alg": "A256GCM"
  },
  "body": {
    "kid": "$KID",
    "alg": "RSA-OAEP",
    "enc": "A256GCM",
    "data": "dGVzdA"
  },
  "expected_status": 422,
  "expected_error": "crypto_failure"
}
