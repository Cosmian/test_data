{
  "_comment": "Encrypt with a kid that does not exist must return 404",
  "type": "expect_error",
  "endpoint": "/v1/crypto/encrypt",
  "body": {
    "kid": "00000000-0000-0000-0000-000000000000",
    "alg": "dir",
    "enc": "A256GCM",
    "data": "dGVzdA"
  },
  "expected_status": 404,
  "expected_error": "not_found"
}
