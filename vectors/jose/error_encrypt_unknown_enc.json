{
  "_comment": "Encrypt with unknown enc algorithm must return 400",
  "type": "expect_error",
  "endpoint": "/v1/crypto/encrypt",
  "setup_key": {
    "kty": "oct",
    "alg": "A256GCM"
  },
  "body": {
    "kid": "$KID",
    "alg": "dir",
    "enc": "A999XYZ",
    "data": "dGVzdA"
  },
  "expected_status": 400,
  "expected_error": "bad_request"
}
